# Copy this file to .env and fill in your values for production.
# For local development, none of these are required (SQLite + DEBUG=True work out of the box).

# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-random-secret-key

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Comma-separated list of trusted origins for CSRF (include scheme)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: PostgreSQL connection string. If unset, SQLite is used.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional: disable forced HTTPS redirect if your platform handles it
# SECURE_SSL_REDIRECT=False
